# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="CreaterHub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# Frontend URL (Next.js) — used for CORS + Sanctum stateful domains
FRONTEND_URL=http://localhost:3000

# Platform domain — creators get {slug}.PLATFORM_DOMAIN
PLATFORM_DOMAIN=createrhub.in

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=createrhub
DB_USERNAME=createrhub
DB_PASSWORD=secret

# ─── Cache & Session ──────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=createrhub_
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.localhost

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── File Storage (Cloudflare R2 — S3-compatible) ────────────────────────────
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=createrhub
AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
AWS_URL=https://your-public-bucket-url.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=true
# For local dev with MinIO, use instead:
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT=http://localhost:9000
# AWS_BUCKET=createrhub

# ─── Email ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@createrhub.in"
MAIL_FROM_NAME="${APP_NAME}"
# Production (Resend):
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_your_resend_api_key
# MAIL_ENCRYPTION=tls

# ─── Mux (Video Hosting) ──────────────────────────────────────────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-signing-secret

# ─── Razorpay (India Payments) ────────────────────────────────────────────────
# Platform-level key — for subscription fees creators pay to you
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── Stripe (International Payments) ─────────────────────────────────────────
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Google OAuth (Creator Login) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback"

# ─── WhatsApp OTP (Student Login via Gupshup) ────────────────────────────────
WHATSAPP_API_URL=https://api.gupshup.io/sm/api/v1
WHATSAPP_API_KEY=your-gupshup-api-key
WHATSAPP_SOURCE_NUMBER=+91XXXXXXXXXX
WHATSAPP_APP_NAME=createrhub

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Sentry (Error Monitoring) ────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS="localhost:3000,127.0.0.1:3000"
